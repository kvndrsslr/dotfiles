#!/usr/bin/env sh
# load scripting additions
sudo yabai --load-sa

# global settings
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off #autoraise
yabai -m config window_placement             second_child
yabai -m config window_topmost               off
yabai -m config window_shadow                off
yabai -m config window_opacity               on
#yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.96
yabai -m config window_border                on
yabai -m config window_border_width          6
yabai -m config active_window_border_color   0xff3c3836
yabai -m config normal_window_border_color   0x1
yabai -m config insert_feedback_color        0xffd75f5f
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 off
yabai -m config mouse_modifier               none
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

# general space settings
yabai -m config layout                       bsp
yabai -m config top_padding                  46
yabai -m config bottom_padding               23
yabai -m config left_padding                 23
yabai -m config right_padding                23
yabai -m config window_gap                   10 

# rules
yabai -m rule --add app="^System Preferences.*$" sticky=on layer=above manage=off
yabai -m rule --add app="^Vitamin-R 3$" sticky=on layer=above manage=off
yabai -m rule --add app="^Lunar$" manage=off sticky=on
yabai -m rule --add app="^Wally$" manage=off sticky=on
yabai -m rule --add app="^League of Legends$" manage=off
yabai -m rule --add app="^Ableton" manage=off
yabai -m rule --add app="^Tweetbot$" title="^$" manage=off
yabai -m rule --add app="^JetBrains Toolbox$" manage=off
yabai -m rule --add app="^ROLI Connect$" manage=off
yabai -m rule --add app="^VLC$" manage=off
# signals
#yabai -m signal --add event=application_activated app="^Alacritty" action='yabai -m config active_window_opacity 1.0'
#yabai -m signal --add event=application_deactivated app="^Alacritty" action='yabai -m config active_window_opacity 1.0'

usb="osascript /Users/kvn/bin/updateSimpleBar.scpt"
yabai -m signal --add event=space_changed action="${usb} spaces"
yabai -m signal --add event=display_changed action="${usb} spaces"
yabai -m signal --add event=space_changed action="${usb} process"
yabai -m signal --add event=window_focused action="${usb} process"
yabai -m signal --add event=window_focused action="${usb} spaces"
yabai -m signal --add event=application_front_switched action="${usb} process"
yabai -m signal --add event=application_front_switched action="${usb} spaces"
yabai -m signal --add event=window_destroyed action="${usb} process"
yabai -m signal --add event=window_destroyed action="${usb} spaces"
yabai -m signal --add event=window_title_changed action="${usb} process"

#echo "yabai configuration loaded.."

hs -A -c 'stackline:init()'
osascript -e 'activate app id "tracesOf.Uebersicht"'
